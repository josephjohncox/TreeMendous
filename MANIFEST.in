# Source distributions are rebuild inputs, never snapshots of the host build.
include README.md
include LICENSE
include pyproject.toml
include setup.py
include setup_gpu.py
include setup_metal.py
include Justfile

recursive-include treemendous *.py *.pyi
include treemendous/py.typed
recursive-include treemendous/cpp *.cpp *.h *.cu *.mm *.metal
recursive-include tests *.py
recursive-include scripts *.py
recursive-include docs *
recursive-include examples *

# Generated/host-specific exclusions must follow every recursive include.
global-exclude *.py[cod]
global-exclude *.so *.pyd *.dll *.dylib
global-exclude *.o *.obj *.a *.lib
global-exclude *.air *.metallib
global-exclude .DS_Store
global-exclude .context.md
global-exclude .gitrepo
global-exclude *~
prune build
prune dist
prune wheelhouse
prune .venv
prune treemendous.egg-info
prune docs/_build
recursive-exclude * __pycache__/*
