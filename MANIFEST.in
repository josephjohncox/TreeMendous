# Source distributions are rebuild inputs, never snapshots of the host build.
include README.md
include LICENSE
include pyproject.toml
include setup.py
include setup_gpu.py
include setup_metal.py
include Justfile

recursive-include treemendous *.py
recursive-include treemendous/cpp *.cpp *.h *.cu *.mm *.metal
recursive-include tests *.py
recursive-include scripts *.py

# Generated/host-specific files are forbidden in sdists.
global-exclude *.py[cod]
global-exclude *.so *.pyd *.dll *.dylib
global-exclude *.o *.obj *.a *.lib
global-exclude *.air *.metallib
global-exclude .DS_Store
global-exclude *~
prune build
prune dist
prune wheelhouse
prune .venv
prune treemendous.egg-info
